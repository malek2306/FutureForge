      <TextField fx:id="tel" layoutX="220.0" layoutY="200.0" promptText="Tel" style="-fx-background-radius: 50px;" />
      <Button fx:id="submit" layoutX="220.0" layoutY="629.0" mnemonicParsing="false" onAction="#submit" prefHeight="50.0" prefWidth="149.0" text="Submit!" />
