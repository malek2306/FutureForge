<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.AdminController">
   <children>
      <ListView fx:id="list" layoutX="93.0" layoutY="39.0" onMouseClicked="#OnMouseClick" prefHeight="323.0" prefWidth="149.0" />
      <TextField fx:id="nom" layoutX="300.0" layoutY="65.0" promptText="Nom" />
      <TextField fx:id="prenom" layoutX="300.0" layoutY="98.0" promptText="Prenom" />
      <TextField fx:id="email" layoutX="300.0" layoutY="170.0" promptText="Email" />
      <TextField fx:id="tel" layoutX="300.0" layoutY="205.0" promptText="Tel" />
      <PasswordField fx:id="mdp" layoutX="300.0" layoutY="242.0" promptText="mot de passe" />
      <TextField fx:id="uname" layoutX="300.0" layoutY="136.0" promptText="Username" />
      <Button fx:id="delete" layoutX="300.0" layoutY="275.0" mnemonicParsing="false" onAction="#DeleteUser" text="Delete" />
      <Button fx:id="modify" layoutX="398.0" layoutY="275.0" mnemonicParsing="false" onAction="#DeleteUser" text="Modify" />
   </children>
